# ZorkVDO Backend Environment Configuration
# Copy this file to .env and fill in real values. NEVER commit .env.

# ─────────────────────────────────────────────────────────────
# App
# ─────────────────────────────────────────────────────────────
APP_NAME=ZorkVDO Backend
APP_ENV=development            # development | staging | production
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO             # DEBUG | INFO | WARNING | ERROR
APP_CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# ─────────────────────────────────────────────────────────────
# Security / JWT
# ─────────────────────────────────────────────────────────────
# Generate with:  openssl rand -hex 32
JWT_SECRET=CHANGE_ME_TO_A_64_CHAR_RANDOM_HEX_STRING
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=30
JWT_REFRESH_TTL_DAYS=14
PASSWORD_MIN_LENGTH=8

# ─────────────────────────────────────────────────────────────
# Storage backend:  local | s3 | firebase
# ─────────────────────────────────────────────────────────────
STORAGE_BACKEND=local
STORAGE_LOCAL_ROOT=./storage_local
STORAGE_BUCKET=zorkvdo-media
# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=zorkvdo
S3_SECRET_KEY=zorkvdo_secret
S3_REGION=us-east-1
S3_USE_PATH_STYLE=true

# ─────────────────────────────────────────────────────────────
# Database:  firestore | memory
#   - memory:    in-process dict-backed store (dev/tests only)
#   - firestore: real Firebase Firestore
# ─────────────────────────────────────────────────────────────
DATABASE_BACKEND=memory
FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS_PATH=./firebase-service-account.json

# ─────────────────────────────────────────────────────────────
# Celery / Redis
# ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─────────────────────────────────────────────────────────────
# AI Providers (fill in when ready - all optional at runtime)
# ─────────────────────────────────────────────────────────────
AI_PROVIDER=openai           # openai | anthropic | gemini | mock
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_VISION_MODEL=gpt-4o
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_CHAT_MODEL=claude-3-5-sonnet-20241022
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro

# ─────────────────────────────────────────────────────────────
# Video analysis tunables
# ─────────────────────────────────────────────────────────────
ANALYSIS_SCENE_THRESHOLD=27.0   # PySceneDetect content threshold
ANALYSIS_SAMPLE_FPS=2.0         # frames sampled per second for CV passes
ANALYSIS_MAX_VIDEO_SECONDS=600  # reject uploads longer than this
ANALYSIS_OCR_LANGUAGES=en
ANALYSIS_YOLO_MODEL=yolov8n.pt
ANALYSIS_ENABLE_FACE=true
ANALYSIS_ENABLE_POSE=true

# ─────────────────────────────────────────────────────────────
# Upload limits
# ─────────────────────────────────────────────────────────────
UPLOAD_MAX_BYTES=524288000      # 500 MB
UPLOAD_ALLOWED_VIDEO_MIMES=video/mp4,video/quicktime,video/webm,video/x-matroska
UPLOAD_ALLOWED_IMAGE_MIMES=image/jpeg,image/png,image/webp
