# ════════════════════════════════════════════════════════════════
#  ZorkVDO — Environment Configuration Template
#  Copy this file to `.env` and fill in real values.
#  NEVER commit `.env` to git.
# ════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────
# APP
# ─────────────────────────────────────────────────────────────
APP_NAME=ZorkVDO Backend
APP_ENV=development            # development | staging | production
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO             # DEBUG | INFO | WARNING | ERROR
APP_CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# ─────────────────────────────────────────────────────────────
# BACKEND
# ─────────────────────────────────────────────────────────────
BASE_API_URL=http://localhost:8000/api/v1
BACKEND_URL=http://localhost:8000

# ─────────────────────────────────────────────────────────────
# SECURITY
#  Generate with:  openssl rand -hex 32
# ─────────────────────────────────────────────────────────────
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=30
JWT_REFRESH_TTL_DAYS=14
PASSWORD_MIN_LENGTH=8
# 32-byte hex key for field-level AES encryption — generate with: openssl rand -hex 16
ENCRYPTION_KEY=

# ─────────────────────────────────────────────────────────────
# GEMINI  (Google AI)
# ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro
GEMINI_VISION_MODEL=gemini-1.5-pro
GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# ─────────────────────────────────────────────────────────────
# OTHER AI PROVIDERS (optional — pluggable via AI_PROVIDER)
# ─────────────────────────────────────────────────────────────
AI_PROVIDER=mock               # mock | gemini | openai | anthropic
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_VISION_MODEL=gpt-4o
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_CHAT_MODEL=claude-3-5-sonnet-20241022

# ─────────────────────────────────────────────────────────────
# FIREBASE  (client SDK config — values come from google-services.json)
# ─────────────────────────────────────────────────────────────
FIREBASE_API_KEY=
FIREBASE_PROJECT_ID=
FIREBASE_APP_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_CREDENTIALS_PATH=./config/firebase_config/firebase-service-account.json

# ─────────────────────────────────────────────────────────────
# FIRESTORE
# ─────────────────────────────────────────────────────────────
DATABASE_BACKEND=memory        # memory | firestore
FIRESTORE_CONNECTION_STRING=

# ─────────────────────────────────────────────────────────────
# STORAGE
# ─────────────────────────────────────────────────────────────
STORAGE_PROVIDER=local         # local | s3 | firebase
STORAGE_CONNECTION_STRING=
STORAGE_LOCAL_ROOT=./storage_local
STORAGE_BUCKET=zorkvdo-media

# S3 / MinIO / R2 / Wasabi (when STORAGE_PROVIDER=s3)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1
S3_USE_PATH_STYLE=true

# ─────────────────────────────────────────────────────────────
# NOTIFICATIONS
# ─────────────────────────────────────────────────────────────
FCM_SERVER_KEY=
# Email (pick one: Resend or SMTP)
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
NOTIFICATION_FROM_EMAIL=noreply@zorkvdo.example

# ─────────────────────────────────────────────────────────────
# ANALYTICS
# ─────────────────────────────────────────────────────────────
ANALYTICS_KEY=
ANALYTICS_PROVIDER=none        # none | posthog | mixpanel | amplitude
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com
SENTRY_DSN=

# ─────────────────────────────────────────────────────────────
# VIDEO PROCESSING
# ─────────────────────────────────────────────────────────────
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
OPENCV_PATH=
YOLO_MODEL_PATH=yolov8n.pt
MEDIAPIPE_MODEL_PATH=
OCR_MODEL_PATH=
ANALYSIS_SCENE_THRESHOLD=27.0
ANALYSIS_SAMPLE_FPS=2.0
ANALYSIS_MAX_VIDEO_SECONDS=600
ANALYSIS_OCR_LANGUAGES=en
ANALYSIS_ENABLE_FACE=true
ANALYSIS_ENABLE_POSE=true

# ─────────────────────────────────────────────────────────────
# CLOUD STORAGE  (alias for S3 — used by some integrations)
# ─────────────────────────────────────────────────────────────
CLOUD_STORAGE_KEY=
CLOUD_STORAGE_SECRET=
CLOUD_BUCKET_NAME=

# ─────────────────────────────────────────────────────────────
# CELERY / REDIS
# ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─────────────────────────────────────────────────────────────
# UPLOAD LIMITS
# ─────────────────────────────────────────────────────────────
UPLOAD_MAX_BYTES=524288000     # 500 MB
UPLOAD_ALLOWED_VIDEO_MIMES=video/mp4,video/quicktime,video/webm,video/x-matroska
UPLOAD_ALLOWED_IMAGE_MIMES=image/jpeg,image/png,image/webp

# ─────────────────────────────────────────────────────────────
# PAYMENTS  (optional — wire in when launching paid plans)
# ─────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_CREATOR_MONTHLY=
STRIPE_PRICE_CREATOR_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
