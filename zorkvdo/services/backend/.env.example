# ════════════════════════════════════════════════════════════════
#  ZorkVDO — Environment Configuration Template
#  Copy this file to `.env` and fill in real values.
#  NEVER commit `.env` to git.
# ════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────
# GEMINI  (Google AI)
# ─────────────────────────────────────────────────────────────
AI_PROVIDER=mock                # mock | gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro

# ─────────────────────────────────────────────────────────────
# FIREBASE
# ─────────────────────────────────────────────────────────────
FIREBASE_API_KEY=
FIREBASE_PROJECT_ID=
FIREBASE_APP_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_CREDENTIALS_PATH=./config/firebase_config/firebase-service-account.json

# ─────────────────────────────────────────────────────────────
# FIRESTORE
# ─────────────────────────────────────────────────────────────
DATABASE_BACKEND=firestore        # memory | firestore

# ─────────────────────────────────────────────────────────────
# STORAGE
# ─────────────────────────────────────────────────────────────
STORAGE_PROVIDER=local            # local | s3 | firebase
STORAGE_LOCAL_ROOT=./storage_local
STORAGE_BUCKET=zorkvdo-media
# S3-compatible (only when STORAGE_PROVIDER=s3)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1
S3_USE_PATH_STYLE=true

# ─────────────────────────────────────────────────────────────
# NOTIFICATIONS
# ─────────────────────────────────────────────────────────────
FCM_SERVER_KEY=

# ─────────────────────────────────────────────────────────────
# ANALYTICS
# ─────────────────────────────────────────────────────────────
# Firebase Analytics + Crashlytics are configured client-side
# via google-services.json (Flutter app). No backend env vars needed.

# ─────────────────────────────────────────────────────────────
# BACKEND
# ─────────────────────────────────────────────────────────────
BASE_API_URL=http://localhost:8000/api/v1
BACKEND_URL=http://localhost:8000
APP_ENV=development               # development | staging | production
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR
APP_CORS_ORIGINS=http://localhost:8080,http://localhost:3000

# ─────────────────────────────────────────────────────────────
# VIDEO PROCESSING
# ─────────────────────────────────────────────────────────────
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
YOLO_MODEL_PATH=yolo11n.pt
MEDIAPIPE_MODEL_PATH=
OCR_MODEL_PATH=
ANALYSIS_SCENE_THRESHOLD=27.0
ANALYSIS_SAMPLE_FPS=2.0
ANALYSIS_MAX_VIDEO_SECONDS=600
ANALYSIS_OCR_LANGUAGES=en
ANALYSIS_ENABLE_FACE=true
ANALYSIS_ENABLE_POSE=true

# ─────────────────────────────────────────────────────────────
# CELERY / REDIS  (background workers — infra, not user-facing)
# ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─────────────────────────────────────────────────────────────
# UPLOAD LIMITS
# ─────────────────────────────────────────────────────────────
UPLOAD_MAX_BYTES=524288000        # 500 MB
UPLOAD_ALLOWED_VIDEO_MIMES=video/mp4,video/quicktime,video/webm,video/x-matroska
UPLOAD_ALLOWED_IMAGE_MIMES=image/jpeg,image/png,image/webp
